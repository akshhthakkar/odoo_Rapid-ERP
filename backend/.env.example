# Database Connection URL (PostgreSQL)
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# JWT Auth Configuration
JWT_SECRET="generate-a-long-random-string-here"
JWT_EXPIRES_IN="30m"

# Port (optional, defaults to 3000)
PORT=3000

# Deployed Frontend URL (for CORS allowance and email links)
# Example: FRONTEND_URL="https://your-frontend-domain.vercel.app"
FRONTEND_URL="http://localhost:5173"

# Brevo (Sendinblue) Email Provider Credentials
BREVO_API_KEY="your-brevo-api-key"
BREVO_SMTP_USER="your-smtp-username"
EMAIL_FROM="your-verified-sender-email@domain.com"
